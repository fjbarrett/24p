# ─────────────────────────────────────────────
# NextAuth
# ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_CALLBACK_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Google OAuth
# https://console.cloud.google.com/apis/credentials
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─────────────────────────────────────────────
# TMDB API
# https://www.themoviedb.org/settings/api
# ─────────────────────────────────────────────
TMDB_API_KEY=your-tmdb-api-key

# ─────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/24p
DB_MAX_CONNECTIONS=5
# TLS verification mode. Production requires a verifying mode (verify-full);
# no-verify/allow/prefer are rejected when NODE_ENV=production.
DB_SSLMODE=disable
# For a self-signed or custom-CA server cert, provide the PEM as one-line
# base64 so verification stays on:
#   openssl s_client -starttls postgres -connect <host>:5432 -showcerts </dev/null \
#     | openssl x509 -outform PEM | base64 | tr -d '\n'
#DB_CA_CERT_BASE64=
# Optional extra pin: the server cert's SHA-256 fingerprint (colons optional).
#   openssl x509 -in cert.pem -noout -fingerprint -sha256
#DB_CERT_FINGERPRINT_SHA256=

# ─────────────────────────────────────────────
# Admin
# Comma-separated allowlist for /admin. Empty = nobody (deny by default).
# ─────────────────────────────────────────────
#ADMIN_EMAILS=you@example.com

# ─────────────────────────────────────────────
# Docker overrides (used by docker-compose.yml)
# ─────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=24p

# ─────────────────────────────────────────────
# Anthropic (AI suggestions)
# https://console.anthropic.com
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─────────────────────────────────────────────
# OMDb (IMDb ratings, keyed by imdb id — cached in Postgres)
# https://www.omdbapi.com/apikey.aspx  (free tier: 1000/day)
# ─────────────────────────────────────────────
OMDB_API_KEY=your-omdbapi-key

# ─────────────────────────────────────────────
# Optional
# ─────────────────────────────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_NO_INDEX=true
